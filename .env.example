# Mobile app — Phase 3 cloud sync env vars.
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored;
# only `.env.example` is committed.
#
# All three values are safe to ship in the client bundle:
#  - Supabase URL + anon key are designed to be public; RLS gates access.
#  - The PowerSync instance URL is a public WebSocket endpoint; PowerSync
#    authenticates via the Supabase JWT.
#
# Never put the Supabase service role key here (or anywhere committed).

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_POWERSYNC_URL=

# Google Sign-In OAuth client IDs (from Google Cloud Console).
# iOS: type "iOS", bundle id com.myozawwin.horae.
# Android: type "Android", package com.myozawwin.horae + SHA-1 of signing key.
# Public client IDs — safe to ship; the app exchanges the resulting ID token
# for a Supabase session via signInWithIdToken().
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
